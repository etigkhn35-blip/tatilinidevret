{
  "functions": [
    {
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint"
      ],
      "source": "functions"
    }
  ],
  "emulators": {
    "functions": {
      "port": 5005
    },
    "firestore": {
      "port": 8081
    },
    "auth": {
      "port": 9100
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 5050
    },
    "hosting": {
      "port": 5000
    },
    "singleProjectMode": true
  },
 
  "hosting": {
    "public": "out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }]
  }
}
