"use client";

import { useEffect, useState } from "react";
import { db } from "@/lib/firebaseConfig";
import {
  collection,
  onSnapshot,
  query,
  orderBy,
  updateDoc,
  doc
} from "firebase/firestore";
import { Bell } from "lucide-react";
import { useRouter } from "next/navigation";



export default function AdminNotifications() {
  const [list, setList] = useState<any[]>([]);
  const [open, setOpen] = useState(false);
  const router = useRouter();

  // 🔔 Yeni bildirim sesi
  const playSound = () => {
    const audio = new Audio("/sounds/notify.mp3");
    audio.volume = 1;
    audio.play().catch(() => {});
  };

  useEffect(() => {
    const q = query(
      collection(db, "admin_notifications"),
      orderBy("createdAt", "desc")
    );

    const unsub = onSnapshot(q, (snap) => {
      const newList = snap.docs.map((d) => ({
        id: d.id,
        ...d.data()
      }));

      // 📢 Yeni okunsuz bildirim geldiyse ses çal
      if (newList.some((n) => !n.read) && list.length !== 0) {
        playSound();
      }

      setList(newList);
    });

    return () => unsub();
  }, []);

  const unread = list.filter((i) => !i.read).length;

  const handleClickNotification = async (item: any) => {
    // Bildirimi okundu yap
    await updateDoc(doc(db, "admin_notifications", item.id), {
      read: true
    });

    // Popup kapanır
    setOpen(false);

    // ➡️ Bildirime göre yönlendir
    if (item.path) {
      router.push(item.path);
      return;
    }

    // --- ÖZEL YÖNLENDİRMELER ---
    if (item.type === "support") {
      router.push("/admin/destek-talepleri");
      return;
    }

    if (item.type === "new_user") {
      router.push("/admin/kullanicilar");
      return;
    }

    if (item.type === "chat") {
      router.push(`/admin/mesajlar/${item.chatId}`);
      return;
    }
  };

  return (
    <div className="relative">
      {/* 🔔 Bildirim butonu */}
      <button
        onClick={() => setOpen(!open)}
        className="relative p-2 rounded-lg hover:bg-gray-100 transition"
      >
        <Bell className="w-6 h-6 text-gray-700" />
        {unread > 0 && (
          <span className="absolute top-1 right-1 bg-red-600 text-white text-xs px-1.5 py-0.5 rounded-full">
            {unread}
          </span>
        )}
      </button>

      {/* 🔽 Bildirim Dropdown */}
      {open && (
        <div className="absolute right-0 mt-2 w-80 bg-white border rounded-xl shadow-xl z-50">
          <div className="p-3 border-b font-semibold text-gray-800">
            Bildirimler
          </div>

          <div className="max-h-80 overflow-y-auto">
            {list.length === 0 && (
              <p className="text-center text-gray-500 py-6">
                Henüz bildirim yok.
              </p>
            )}

            {list.map((item) => (
              <div
                key={item.id}
                onClick={() => handleClickNotification(item)}
                className={`p-3 cursor-pointer border-b hover:bg-gray-50 ${
                  !item.read ? "bg-blue-50" : "bg-white"
                }`}
              >
                <div className="font-medium text-sm text-gray-800">
                  {item.title || "Bildirim"}
                </div>

                <div className="text-xs text-gray-500">
                  {item.email || ""}
                </div>

                <div className="text-xs text-gray-400 mt-1">
                  {item.createdAt?.toDate
                    ? item.createdAt.toDate().toLocaleString("tr-TR")
                    : ""}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}
